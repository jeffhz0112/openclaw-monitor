# OpenClaw Monitor 配置文件

# OpenClaw Dashboard 地址（必填）
OPENCLAW_URL=http://192.168.31.69:18789

# OpenClaw Gateway 地址（必填）
OPENCLAW_GATEWAY=ws://192.168.31.69:18789

# Telegram Bot Token（可选，用于通知）
# 创建 Bot: 与 @BotFather 对话，发送 /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID（可选，用于通知）
# 获取方式: 向你的 Bot 发送消息后访问
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# 检查间隔（秒，默认60秒）
CHECK_INTERVAL=60

# 历史数据保留天数（默认7天）
HISTORY_DAYS=7
